{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n \"API,WEB\" -c \"blue,green\" \"pnpm --filter @workspace/api-server run dev\" \"pnpm --filter @workspace/task-manager run dev\"",
    "build": "pnpm run typecheck && pnpm --filter @workspace/task-manager run build && pnpm --filter @workspace/api-server run build",
    "start": "pnpm --filter @workspace/api-server run start",
    "db:push": "pnpm --filter @workspace/db run push",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  }
}
